{
  "__inputs": [],
  "__requires": [
    {
      "id": "grafana",
      "name": "Grafana",
      "type": "grafana",
      "version": "11.0.0"
    },
    {
      "id": "postgres",
      "name": "PostgreSQL",
      "type": "datasource",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "User feedback (thumbs up/down) from the RAG chatbot",
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "postgres",
        "uid": "paradedb-ds"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "paradedb-ds"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*) AS \"Total Feedback\" FROM feedback",
          "refId": "A"
        }
      ],
      "title": "Total Feedback",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "paradedb-ds"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 75
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "id": 2,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "paradedb-ds"
          },
          "format": "table",
          "rawSql": "SELECT ROUND(100.0 * COUNT(*) FILTER (WHERE vote = 'up') / NULLIF(COUNT(*), 0), 1) AS \"Helpfulness %\" FROM feedback",
          "refId": "A"
        }
      ],
      "title": "Helpfulness %",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "paradedb-ds"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Up"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Down"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "paradedb-ds"
          },
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', created_at) AS \"time\", COUNT(*) FILTER (WHERE vote = 'up') AS \"Up\", COUNT(*) FILTER (WHERE vote = 'down') AS \"Down\" FROM feedback WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Votes Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "paradedb-ds"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "id": 4,
      "options": {
        "barWidth": 0.7,
        "fillOpacity": 80,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "orientation": "auto",
        "stacking": "none",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "paradedb-ds"
          },
          "format": "table",
          "rawSql": "SELECT COALESCE(space, 'Unknown') AS \"Team\", COUNT(*) AS \"Votes\" FROM feedback GROUP BY space ORDER BY \"Votes\" DESC",
          "refId": "A"
        }
      ],
      "title": "Votes by Team",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "paradedb-ds"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 75
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 12
      },
      "id": 5,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": true
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "paradedb-ds"
          },
          "format": "table",
          "rawSql": "SELECT COALESCE(space, 'Unknown') AS \"metric\", ROUND(100.0 * COUNT(*) FILTER (WHERE vote = 'up') / NULLIF(COUNT(*), 0), 1) AS \"Helpfulness %\" FROM feedback GROUP BY space",
          "refId": "A"
        }
      ],
      "title": "Helpfulness % by Team",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "paradedb-ds"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Vote"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "down": {
                        "color": "red",
                        "index": 1,
                        "text": "down"
                      },
                      "up": {
                        "color": "green",
                        "index": 0,
                        "text": "up"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 8
      },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "paradedb-ds"
          },
          "format": "table",
          "rawSql": "SELECT created_at AS \"Time\", COALESCE(space, '\u2014') AS \"Team\", question AS \"Question\", vote AS \"Vote\" FROM feedback ORDER BY created_at DESC LIMIT 20",
          "refId": "A"
        }
      ],
      "title": "Recent Feedback",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "rag",
    "feedback"
  ],
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timepicker": {},
